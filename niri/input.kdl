input {
    // focus-follows-mouse max-scroll-amount="90%"
    keyboard {
        repeat-delay 200
        repeat-rate 30
        xkb {
            layout "us,es"
        }
    }
    mouse {
        accel-speed 0
        accel-profile "flat"
    }
    touchpad {
        natural-scroll
        tap
        dwt
        dwtp
        accel-speed 0.0
        disabled-on-external-mouse
    }
    trackpoint {
        off
    }
}
